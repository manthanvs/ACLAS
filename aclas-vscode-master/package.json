{
  "publisher": "aclas-org",
  "name": "aclas",
  "displayName": "ACLAS Telemetry",
  "version": "1.0.0",
  "description": "Adaptive Coding Lifecycle Analytics System Tracker",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.99.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "aclas.getToken",
        "title": "ACLAS: Enter API Token"
      },
      {
        "command": "aclas.stopTracking",
        "title": "ACLAS: Stop Tracking"
      }
    ],
    "configuration": {
      "title": "ACLAS Settings",
      "properties": {
        "aclas.serverEntrypoint": {
          "type": "string",
          "default": "http://localhost:8000/api/heartbeats/",
          "description": "URL to your local Django Backend"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --devtool nosources-source-map --config ./build/node-extension.webpack.config.js",
    "watch": "webpack --watch --devtool nosources-source-map --config ./build/node-extension.webpack.config.js",
    "package": "webpack --mode production --config ./build/node-extension.webpack.config.js"
  },
  "dependencies": {
    "got": "14.4.7"
  },
  "devDependencies": {
    "@types/got": "^9.6.12",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.99.0",
    "@vscode/vsce": "^3.6.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "webpack": "^5.100.2",
    "webpack-cli": "^6.0.1"
  }
}
